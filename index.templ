package main

templ hello() {
    <!DOCTYPE html>
    <html>
        <head>
            <script type="module" src="https://cdn.jsdelivr.net/gh/starfederation/datastar@v1.0.2/bundles/datastar.js"></script>
        </head>
        <body>
            <button data-on:click="@get('/endpoint')">
                Open the pod bay doors, HAL.
            </button>
            <div id="hal"></div>
        </body>
    </html>
}
